{
  "data": {
    "target_total": 30000,
    "cvss_version": "3.1",
    "min_description_length": 50
  },
  "model": {
    "base_model": "answerdotai/ModernBERT-base",
    "max_length": 192,
    "batch_size": 16,
    "learning_rate": 1e-5,
    "dropout": 0.3,
    "label_smoothing": 0.1,
    "weight_decay": 0.01,
    "mc_dropout_passes": 5,
    "loss": "cross_entropy",
    "class_weights": true,
    "warmup_ratio": 0.1,
    "gradient_clip": 1.0,
    "epochs": 20,
    "patience": 5,
    "seed": 42,
    "num_labels": 4,
    "label_map": {"Low": 0, "Medium": 1, "High": 2, "Critical": 3}
  },
  "evaluation": {
    "test_split": 0.15,
    "val_split": 0.15
  }
}
